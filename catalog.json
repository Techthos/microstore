      "display_name": "deskbluez",
      "description": "Bluetooth desk and device management utility.",
      "mcp": {
        "command": "microapp-deskbluez",
        "args": ["serve"]
      }
    },
    {
      "repo": "Techthos/microapp-crm",
      "category": "tools",
